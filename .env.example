# Vercel 프로젝트 설정 > Settings > Environment Variables 에 아래 값을 등록하세요.
# (이 파일 자체는 예시일 뿐이며, 실제 값은 절대 git에 커밋하지 마세요.)

# Google AI Studio(https://aistudio.google.com/apikey)에서 발급한 Gemini API 키.
# Cloud Vision과 달리 결제 계정 연결 없이 무료 등급 키를 바로 받을 수 있다.
GEMINI_API_KEY=

# 오늘 인식 횟수를 세서 무료 한도 근처(200건)에서 자동으로 멈추기 위한 저장소.
# Vercel 대시보드 > Storage 탭 > Redis(Upstash) 연동을 이 프로젝트에 Connect하면
# 아래 두 값은 Vercel이 자동으로 채워준다 — 직접 입력할 필요 없음.
# (연동을 안 하면 사용량 한도 체크 없이 그냥 매번 Gemini를 호출한다.)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
